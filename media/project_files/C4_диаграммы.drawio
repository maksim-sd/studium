        <mxCell id="c-exec" value="Исполнитель&#10;[Студент]" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="70" width="80" height="90" as="geometry" />
