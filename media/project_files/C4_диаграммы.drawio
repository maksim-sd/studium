        <mxCell id="c-admin" value="Администратор&#10;[Сотрудник вуза]" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="690" width="80" height="90" as="geometry" />
        </mxCell>

        <!-- Граница системы -->
        <mxCell id="boundary" value="Онлайн-платформа формирования профессиональных компетенций" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#444444;fontFamily=Times New Roman;fontSize=12;fontStyle=2;verticalAlign=top;align=center;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="730" height="500" as="geometry" />
        </mxCell>

        <!-- Контейнер: SPA -->
        <mxCell id="cont-spa" value="Клиентское веб-приложение&#10;&#10;[Контейнер: React, SPA]&#10;&#10;Одностраничное приложение,&#10;реализующее пользовательский&#10;интерфейс в браузере" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="110" y="300" width="230" height="120" as="geometry" />
        </mxCell>

        <!-- Контейнер: API -->
        <mxCell id="cont-api" value="Серверное приложение (REST API)&#10;&#10;[Контейнер: Python, Django, Django Ninja]&#10;&#10;Реализует бизнес-логику и предоставляет&#10;REST API в формате JSON. Модули:&#10;user, project_exchange, shop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="110" y="520" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- Контейнер: Админка -->
        <mxCell id="cont-admin" value="Административная панель&#10;&#10;[Контейнер: Django Unfold]&#10;&#10;Управление данными платформы&#10;и аналитический дашборд&#10;(мониторинг активности)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="520" width="250" height="140" as="geometry" />
        </mxCell>

        <!-- Контейнер: БД -->
        <mxCell id="cont-db" value="База данных&#10;&#10;[Контейнер: PostgreSQL / SQLite]&#10;&#10;Хранение данных пользователей,&#10;проектов, чатов, отзывов&#10;и данных магазина" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
