<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram name="C4 - Контекст (уровень 1)" id="c4-context">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ctx-title" value="Диаграмма контекста системы (C4, уровень 1)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontFamily=Times New Roman;" vertex="1" parent="1">
          <mxGeometry x="120" y="30" width="610" height="30" as="geometry" />
        </mxCell>

        <!-- Актёры -->
        <mxCell id="actor-cust" value="Заказчик&#10;&#10;[Представитель организации]&#10;Создаёт проекты, завершает их и&#10;оставляет отзывы исполнителям" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="90" y="120" width="120" height="120" as="geometry" />
        </mxCell>
        <mxCell id="actor-mod" value="Модератор&#10;&#10;[Сотрудник вуза]&#10;Проверяет и публикует проекты,&#10;назначает исполнителей" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="365" y="120" width="120" height="120" as="geometry" />
        </mxCell>
        <mxCell id="actor-exec" value="Исполнитель&#10;&#10;[Студент]&#10;Откликается на проекты, выполняет&#10;их и взаимодействует в чате" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="120" width="120" height="120" as="geometry" />
        </mxCell>

        <!-- Система -->
        <mxCell id="ctx-system" value="Онлайн-платформа формирования&#10;профессиональных компетенций&#10;&#10;[Программная система]&#10;&#10;Обеспечивает единое цифровое пространство&#10;для публикации проектов, поиска исполнителей,&#10;выполнения проектов и коммуникации участников" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0B4884;fontColor=#FFFFFF;fontFamily=Times New Roman;fontSize=12;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="285" y="470" width="280" height="160" as="geometry" />
        </mxCell>

        <!-- Связи -->
        <mxCell id="e-cust" value="Публикует и завершает проекты,&#10;оставляет отзывы [HTTPS]" style="endArrow=block;html=1;fontFamily=Times New Roman;fontSize=10;rounded=0;endFill=1;strokeColor=#707070;fontColor=#404040;" edge="1" parent="1" source="actor-cust" target="ctx-system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-mod" value="Модерирует проекты,&#10;назначает исполнителей [HTTPS]" style="endArrow=block;html=1;fontFamily=Times New Roman;fontSize=10;rounded=0;endFill=1;strokeColor=#707070;fontColor=#404040;" edge="1" parent="1" source="actor-mod" target="ctx-system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-exec" value="Откликается, выполняет&#10;проекты, общается [HTTPS]" style="endArrow=block;html=1;fontFamily=Times New Roman;fontSize=10;rounded=0;endFill=1;strokeColor=#707070;fontColor=#404040;" edge="1" parent="1" source="actor-exec" target="ctx-system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="C4 - Контейнеры (уровень 2)" id="c4-containers">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
