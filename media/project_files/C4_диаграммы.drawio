        <!-- Связи актёры -> SPA -->
        <mxCell id="ce-cust" value="Использует [HTTPS]" style="endArrow=block;html=1;fontFamily=Times New Roman;fontSize=10;endFill=1;strokeColor=#707070;fontColor=#404040;" edge="1" parent="1" source="c-cust" target="cont-spa">
          <mxGeometry relative="1" as="geometry" />
