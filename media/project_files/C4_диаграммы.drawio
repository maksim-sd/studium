        <!-- SPA -> API -->
        <mxCell id="ce-spa-api" value="Запросы к API&#10;[HTTPS, REST/JSON,&#10;HTTP Basic Auth]" style="endArrow=block;html=1;fontFamily=Times New Roman;fontSize=10;endFill=1;strokeColor=#707070;fontColor=#404040;" edge="1" parent="1" source="cont-spa" target="cont-api">
