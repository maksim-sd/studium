# Copy to .env and fill in real values before deploying.
# Generate a key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

DEBUG=False

# Comma-separated. Add your server IP / domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# Needed for the Django admin login when DEBUG=False. Include scheme + host (+ port if any).
CSRF_TRUSTED_ORIGINS=http://localhost

# Frontend is served same-origin via nginx, so CORS is usually not needed in prod.
# Fill only if you serve the SPA from a different origin.
CORS_ALLOWED_ORIGINS=

# Number of gunicorn workers.
GUNICORN_WORKERS=3
